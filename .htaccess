RewriteEngine On
RewriteBase /estagio/

# Se for acesso direto a arquivos existentes (CSS, JS, imagens), serve normalmente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ===========================================
# CONFIGURAÇÕES DE SEGURANÇA
# ===========================================

Options -Indexes -MultiViews
ServerSignature Off

# Headers de segurança
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# TUDO que não for arquivo existente vai para router.php
RewriteRule ^(.*)$ router.php?url=$1 [L,QSA]

RewriteRule ^(Controller|Model|View|Helpers|Middleware|Conexao|config|Tasks|Scripts|Includes)/ /estagio/ [R=302,L]

# Redirecionar arquivos sensíveis específicos
RewriteRule \.(env|ini|sql|log|py|sh|key|pem)$ /estagio/ [R=302,L]

# Redirecionar arquivos sensíveis por nome
RewriteRule (encriptionKey|\.env|\.gitignore|\.gitattributes|README)\.(php|md|txt)$ /estagio/ [R=302,L]

# Redirecionar qualquer acesso direto a arquivos PHP (exceto Index.php e router.php)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} \.php$
RewriteCond %{REQUEST_URI} !/(Index\.php|router\.php)$
RewriteRule ^ /estagio/ [R=302,L]

# Redirecionar acesso a arquivos PHP dentro de uploads
RewriteRule ^uploads/.*\.php$ /estagio/ [R=302,L]

# ===========================================
# PERMITIR APENAS ARQUIVOS PÚBLICOS
# ===========================================

# Permitir acesso direto a Assets (CSS, JS, imagens)
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} \.(css|js|jpg|jpeg|png|gif|ico|svg|webp|woff|woff2|ttf|eot|pdf)$ [NC]
RewriteRule ^ - [L]

# Permitir acesso direto a Index.php e router.php
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} /(Index\.php|router\.php)$ [NC]
RewriteRule ^ - [L]



# ===========================================
# ROTEAMENTO PRINCIPAL
# ===========================================

# Se for diretório existente (exceto os protegidos)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ /estagio/ [R=302,L]

# Se for arquivo existente (Assets, etc)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Tudo o resto vai para router.php
RewriteRule ^(.*)$ router.php?url=$1 [L,QSA]

# ===========================================
# 🔐 FORÇAR HTTPS 
# ===========================================
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteRule ^\.git - [F,L]
RedirectMatch 404 /\.git

<FilesMatch "\.(env|sql|bak|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>

RedirectMatch 403 ^/backup
RedirectMatch 403 ^/config
RedirectMatch 403 ^/Temp

# Permitir apenas via router
RewriteCond %{REQUEST_URI} ^/estagio/Controller/
RewriteRule .* - [F]

<Files "encriptionKey.php">
    Require all denied
</Files>

RedirectMatch 403 /\.git

# Redirecionar tudo para o router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ router.php?url=$1 [QSA,L]

# BLOQUEAR acesso direto a pastas sensíveis
RewriteRule ^(Controller|Helpers|Conexao|middleware)/ - [F,L]
Header unset Server